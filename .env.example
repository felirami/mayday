# ── Mayday environment ──

# Required: your Cerebras Inference API key (https://cloud.cerebras.ai). Starts with csk-
CEREBRAS_API_KEY=

# Optional: a real GPU-based OpenAI-compatible provider for the side-by-side speed race.
# If unset, the race shows a clearly-labeled representative GPU baseline.
# Examples: Gemini (OpenAI-compat endpoint), Together AI, OpenAI, Groq, OpenRouter.
# BASELINE_API_KEY=
# BASELINE_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# BASELINE_MODEL=gemini-2.5-flash
# BASELINE_LABEL=Gemini 2.5 Flash (GPU)
# BASELINE_SIM_TPS=75
