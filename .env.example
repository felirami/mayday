# ── Mayday environment ──

# Required: your Cerebras Inference API key (https://cloud.cerebras.ai). Starts with csk-
CEREBRAS_API_KEY=

# Optional: a real GPU-based OpenAI-compatible provider for the side-by-side speed race.
# If unset, the race shows a clearly-labeled representative GPU baseline.
# Best comparison is the SAME model on a GPU — OpenRouter hosts Gemma 4 31B:
# BASELINE_API_KEY=sk-or-v1-...
# BASELINE_BASE_URL=https://openrouter.ai/api/v1
# BASELINE_MODEL=google/gemma-4-31b-it
# BASELINE_LABEL=Gemma 4 31B · GPU (OpenRouter)
# BASELINE_SIM_TPS=75
